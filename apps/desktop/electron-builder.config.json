{
  "productName": "CalDAV Desktop",
  "appId": "com.caldav.desktop.calendar",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "node_modules/**/*",
    "package.json",
    "!**/*.ts",
    "!*.map",
    "!package.json.orig"
  ],
  "asarUnpack": ["node_modules/ms/**/*"],
  "npmRebuild": false,
  "win": {
    "target": ["nsis", "zip"],
    "artifactName": "${productName}-${version}-win.${ext}"
  },
  "linux": {
    "target": ["AppImage", "tar.gz"],
    "artifactName": "${productName}-${version}-linux.${ext}",
    "category": "Office"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "publish": null
}
