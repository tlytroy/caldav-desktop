{
  "productName": "CalDAV Desktop",
  "appId": "com.caldav.desktop.calendar",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "node_modules/**/*",
    "package.json",
    "!**/*.ts",
    "!*.map",
    "!package.json.orig"
  ],
  "win": {
    "target": [
      "zip"
    ],
    "artifactName": "${productName}-${version}-win.${ext}"
  },
  "linux": {
    "target": [
      "AppImage",
      "tar.gz"
    ],
    "artifactName": "${productName}-${version}-linux.${ext}",
    "category": "Office"
  },
  "publish": null
}